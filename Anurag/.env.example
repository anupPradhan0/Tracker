# Database (Postgres via Docker — keep POSTGRES_* in sync with DATABASE_URL)
POSTGRES_USER=anurag
POSTGRES_PASSWORD=anurag_dev
POSTGRES_DB=expense_tracker
POSTGRES_PORT=5433
DATABASE_URL="postgresql://anurag:anurag_dev@localhost:5433/expense_tracker?schema=public"

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (32-byte base64 for AES-256-GCM)
ENCRYPTION_KEY=change-me-32-byte-base64-key-here==

# Email (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Expense Tracker <noreply@example.com>"

# AI models (API keys are saved per user in app Settings)
GEMINI_MODEL=gemini-2.0-flash
COHERE_MODEL=command-r-plus-08-2024

# Docker: host uses DATABASE_URL above; `docker compose --profile app` overrides DB host to `postgres`

# Frontend
VITE_API_URL=http://localhost:4000/api/v1
