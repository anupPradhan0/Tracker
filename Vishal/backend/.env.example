NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://finance:finance@localhost:5434/finance_tracker
JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_NAME=auth_token
COOKIE_SECRET=
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Email via Nodemailer (required for "Email report" button and weekly cron)
# Gmail: Security → 2-Step Verification → App passwords → create one (16 characters, no spaces)
#
# RULE: MAIL_USER must be the SAME @gmail.com account that created MAIL_PASSWORD.
# MAIL_FROM is optional display name only — it cannot be a different Gmail account.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
# Optional sender display name (uses MAIL_USER as the From address for Gmail)
# MAIL_FROM="Finance Tracker"
# Or with the same email as MAIL_USER:
# MAIL_FROM="Finance Tracker" <your@gmail.com>

# Cron protection (optional — recommended in production)
CRON_SECRET=

# Cohere AI (weekly/daily insights, email analysis)
COHERE_API_KEY=
COHERE_MODEL=command-r-plus-08-2024
